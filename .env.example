# Remote postgres URL (required for Trigger local/dev runs)
DATABASE_URL=

# Backstage auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3001

# Trigger.dev (self-hosted)
TRIGGER_API_URL=
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=

# Remote S3-compatible storage (required for Trigger local/dev runs)
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=true
S3_APPLY_PUBLIC_READ_POLICY=false

# Social publishing — Postiz
POSTIZ_API_KEY=
# Override when self-hosting Postiz ({BACKEND_URL}/public/v1)
POSTIZ_API_URL=https://api.postiz.com/public/v1
# Optional: channel ids auto-resolve from GET /integrations when unset
POSTIZ_INSTAGRAM_INTEGRATION_ID=
POSTIZ_FACEBOOK_INTEGRATION_ID=
