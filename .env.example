DATABASE_URL=postgresql://mundialito:mundialito@localhost:5432/mundialito

# Backstage auth
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:3001
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3001

# Object storage (video-worker uploads, social-worker reads public URLs)
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=mundialito-videos
S3_ACCESS_KEY_ID=mundialito
S3_SECRET_ACCESS_KEY=mundialito
S3_PUBLIC_BASE_URL=http://localhost:9000
S3_FORCE_PATH_STYLE=true
S3_APPLY_PUBLIC_READ_POLICY=true

# Social publishing — Postiz (default provider, required)
POSTIZ_API_KEY=
# Override only when self-hosting Postiz ({BACKEND_URL}/public/v1)
POSTIZ_API_URL=https://api.postiz.com/public/v1
# Optional: channel ids auto-resolve from GET /integrations when unset
POSTIZ_INSTAGRAM_INTEGRATION_ID=
POSTIZ_FACEBOOK_INTEGRATION_ID=
SOCIAL_WORKER_POLL_MS=5000

# Video worker
VIDEO_WORKER_POLL_MS=5000
