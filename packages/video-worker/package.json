{
  "name": "@mr/video-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --clear-screen=false --include \"../db/src/**\" --include \"../remotion/src/**\" src/index.ts",
    "worker": "tsx src/index.ts",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@mr/db": "workspace:*",
    "@mr/remotion": "workspace:*",
    "@remotion/bundler": "4.0.477",
    "@remotion/renderer": "4.0.477",
    "@remotion/tailwind-v4": "4.0.477",
    "dotenv": "^17.4.2",
    "tsx": "^4.19.4"
  },
  "devDependencies": {
    "@mr/eslint-config": "workspace:*",
    "@mr/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "typescript": "5.9.2",
    "vitest": "^4.1.8"
  }
}
