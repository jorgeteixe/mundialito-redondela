DATABASE_URL=postgresql://mundialito:mundialito@localhost:5432/mundialito
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=mundialito-videos
S3_ACCESS_KEY_ID=mundialito
S3_SECRET_ACCESS_KEY=mundialito
S3_PUBLIC_BASE_URL=http://localhost:9000
S3_FORCE_PATH_STYLE=true
S3_APPLY_PUBLIC_READ_POLICY=true

# Social publishing (Meta Graph API) — used by @mr/social-worker.
# NOTE: S3_PUBLIC_BASE_URL above must be a public URL Meta can fetch, not
# localhost. For local publishing, expose MinIO via a tunnel and override it.
META_GRAPH_API_VERSION=v21.0
META_IG_USER_ID=
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
# Optional tuning for the async Instagram video container poll.
# META_CONTAINER_POLL_MS=3000
# META_CONTAINER_POLL_MAX_ATTEMPTS=20
# SOCIAL_WORKER_POLL_MS=5000
