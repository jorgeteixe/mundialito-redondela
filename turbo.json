{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "CI",
    "DATABASE_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "NEXT_PUBLIC_BETTER_AUTH_URL",
    "NEXT_DIST_DIR",
    "VIDEO_OUTPUT_DIR",
    "VIDEO_PUBLIC_PATH_PREFIX",
    "VIDEO_WORKER_ID",
    "VIDEO_WORKER_POLL_MS",
    "VIDEO_WORKER_ONCE",
    "REMOTION_ENTRY_POINT",
    "REMOTION_UI_SRC",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_BUCKET",
    "S3_ACCESS_KEY_ID",
    "S3_SECRET_ACCESS_KEY",
    "S3_PUBLIC_BASE_URL",
    "S3_FORCE_PATH_STYLE",
    "S3_APPLY_PUBLIC_READ_POLICY",
    "SOCIAL_WORKER_ID",
    "SOCIAL_WORKER_POLL_MS",
    "SOCIAL_WORKER_ONCE",
    "POSTIZ_API_URL",
    "POSTIZ_API_KEY",
    "POSTIZ_INSTAGRAM_INTEGRATION_ID",
    "POSTIZ_FACEBOOK_INTEGRATION_ID",
    "TRIGGER_API_URL",
    "TRIGGER_SECRET_KEY",
    "TRIGGER_PROJECT_REF",
    "CONFIRM_PUBLISH"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:visual": {
      "dependsOn": ["build-storybook"],
      "outputs": ["artifacts/storybook/**"]
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "build-storybook": {
      "dependsOn": ["^build-storybook"],
      "outputs": ["storybook-static/**"]
    },
    "screenshot:storybook": {
      "dependsOn": ["build-storybook"],
      "outputs": ["artifacts/storybook/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "deploy": {
      "cache": false
    },
    "worker": {
      "cache": false,
      "persistent": true
    }
  }
}
